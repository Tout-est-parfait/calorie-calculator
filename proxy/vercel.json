{
  "rewrites": [
    {
      "source": "/api/kimi/chat/completions",
      "destination": "https://api.moonshot.cn/v1/chat/completions"
    },
    {
      "source": "/api/deepseek/chat/completions",
      "destination": "https://api.moonshot.cn/v1/chat/completions"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer YOUR_KIMI_API_KEY"
        }
      ]
    }
  ]
}
